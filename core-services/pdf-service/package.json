{
  "name": "pdf-service",
  "version": "1.2.1",
  "description": "Starter project for an ES6 RESTful Express API",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch --max-old-space-size=8192 src/index.js",
    "build": "cp -r src dist",
    "start": "node --max-old-space-size=8192 src/index.js",
    "prestart": "npm run build",
    "test": "eslint src"
},
  "engines": {
    "node": ">=22.0.0"
  },
  "proxy": "https://egov-micro-dev.egovernments.org/",
  "eslintConfig": {
    "extends": "eslint:recommended",
    "parserOptions": {
      "ecmaVersion": 7,
      "sourceType": "module"
    },
    "env": {
      "node": true
    },
    "rules": {
      "no-console": 0,
      "no-unused-vars": 1
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/egovernments/core-services.git"
  },
  "author": "Jason Miller <jason@developit.ca>",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.0",
    "body-parser": "^1.20.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "form-data": "^4.0.0",
    "jsonpath": "^1.1.1",
    "kafkajs": "^2.2.4",
    "lodash.get": "^4.4.2",
    "lodash.set": "^4.3.2",
    "moment-timezone": "^0.5.45",
    "morgan": "^1.10.0",
    "pdfmake": "0.2.10",
    "pg": "^8.11.3",
    "qrcode": "^1.5.3",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "pdf-merger-js": "^5.1.1",
    "node-cache": "^5.1.2",
    "async": "^3.2.5",
    "mustache": "^4.2.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "nodemon": "^3.0.2"
  },
  "bugs": {
    "url": "https://github.com/egovernments/core-services/issues"
  },
  "homepage": "https://github.com/egovernments/core-services/blob/master/README.md"
}
